FROM node:18-alpine

# Install dependencies
RUN apk add --no-cache python3 py3-pip ffmpeg && \
    pip3 install --no-cache-dir yt-dlp

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci --production

# Copy source code
COPY . .

# Create temp directory
RUN mkdir -p .temp_media

# Expose port
EXPOSE 3002

# Start the server
CMD ["node", "server-fixed.js"]
