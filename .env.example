# Environment Variables for AURALIS Music Bot

# Spotify API Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# SoundCloud API Credentials
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id_here

# YouTube API Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Rate Limiting (Upstash Redis) - Required for API protection
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Converter Service - Required for YouTube audio processing
CONVERTER_SERVICE_URL=https://your-converter.fly.dev
CONVERTER_SECRET=your_shared_secret_key

# App Configuration
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
PORT=3000
NODE_ENV=development

# Sentry (optional)
SENTRY_DSN=your_sentry_dsn